        <mxCell id="k04SboY_8xgLOiQQaCqn-3" parent="k04SboY_8xgLOiQQaCqn-8" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10;fontStyle=1;" value="Arrow captions" vertex="1">
          <mxGeometry height="22" width="150" x="10" y="7.995555555555711" as="geometry" />
